# Email (SMTP — provider cserélhető, kód nem változik)
# Opció 1 — Brevo (ingyenes 300/nap = 9000/hó): SMTP_HOST=smtp-relay.brevo.com
# Opció 2 — Gmail App Password:                  SMTP_HOST=smtp.gmail.com
# Opció 3 — Iskola saját SMTP:                   SMTP_HOST=mail.iskola.hu
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="SchoolEvents <noreply@schoolevents.hu>"
